<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="RDPWrap Monitor Service" Language="1033" Version="1.0.0" Manufacturer="VibsWorld" UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="RDPWrap Monitor Service" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationComponent" />
      <ComponentRef Id="ServiceInstallComponent" />
      <ComponentRef Id="PathComponent" />
    </Feature>

    <!-- UI Customization -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!-- License agreement -->
    <WixVariable Id="WixUILicenseRtf" Value="installer\LICENSE.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="installer\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="installer\dialog.bmp" />
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="RDPWrap Monitor">
          <Directory Id="ServiceFolder" Name="Service" />
          <Directory Id="SetupFolder" Name="Setup" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="RDPWrap Monitor" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="ServiceFolder">
      <!-- Service executable and dependencies -->
      <Component Id="ServiceExe" Guid="*">
        <File Id="ServiceExeFile" Source="$(var.ServicePath)\RdpWrapMonitor.Service.exe" KeyPath="yes" />
      </Component>
      <Component Id="ServiceDll1" Guid="*">
        <File Id="ServiceDll1File" Source="$(var.ServicePath)\Microsoft.Extensions.Hosting.dll" KeyPath="yes" />
      </Component>
      <Component Id="ServiceDll2" Guid="*">
        <File Id="ServiceDll2File" Source="$(var.ServicePath)\Microsoft.Extensions.Hosting.WindowsServices.dll" KeyPath="yes" />
      </Component>
      <Component Id="ServiceDll3" Guid="*">
        <File Id="ServiceDll3File" Source="$(var.ServicePath)\Microsoft.Extensions.Http.dll" KeyPath="yes" />
      </Component>
      <Component Id="ServiceDll4" Guid="*">
        <File Id="ServiceDll4File" Source="$(var.ServicePath)\System.Security.Cryptography.ProtectedData.dll" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="SetupComponents" Directory="SetupFolder">
      <!-- Setup utility -->
      <Component Id="SetupExe" Guid="*">
        <File Id="SetupExeFile" Source="$(var.SetupPath)\RdpWrapMonitor.Setup.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut Id="SetupShortcut" Name="RDPWrap Monitor Setup" Target="[SetupFolder]RdpWrapMonitor.Setup.exe" WorkingDirectory="SetupFolder" />
        <Shortcut Id="LogShortcut" Name="Open Log Folder" Target="[AppDataFolder]RdpWrapMonitor\logs" />
        <Shortcut Id="ConfigShortcut" Name="Open Config Folder" Target="[AppDataFolder]RdpWrapMonitor" />
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\VibsWorld\RDPWrapMonitor" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <Component Id="ApplicationComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="ReadmeFile" Source="installer\README.rtf" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="ServiceInstallComponent" Directory="ServiceFolder" Guid="*">
      <ServiceInstall Id="ServiceInstaller" Type="ownProcess" Vital="yes" Name="RDPWrap Monitor" DisplayName="RDPWrap Monitor Service" Description="Monitors for rdpwrap.ini updates and automatically updates RDP Wrapper configuration" Start="auto" Account="LocalSystem" ErrorControl="ignore" Interactive="no" />
      <ServiceControl Id="StartService" Start="install" Stop="both" Remove="uninstall" Name="RDPWrap Monitor" Wait="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="PathComponent" Directory="INSTALLFOLDER" Guid="*">
      <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
    </Component>
  </Fragment>
</Wix>
